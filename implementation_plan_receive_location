### Component 6: Sharing Receivers Setup in App Lifecycle
In the App shell (e.g. `main.dart` or root home/dashboard wrapper):
Initialize listeners for incoming share intents:
```dart
StreamSubscription? _intentSub;

@override
void initState() {
  super.initState();
  
  // 1. Listen for share intent while app is running in background/foreground
  _intentSub = ReceiveSharingIntent.instance.getMediaStream().listen((value) {
    _handleSharedIntent(value);
  }, onError: (err) {
    debugPrint("getMediaStream error: $err");
  });

  // 2. Capture share intent that cold-started the app
  ReceiveSharingIntent.instance.getInitialMedia().then((value) {
    _handleSharedIntent(value);
  });
}

void _handleSharedIntent(List<SharedMediaFile> value) async {
  if (value.isEmpty) return;
  
  final sharedText = value.first.path; // Holds shared plain text or url link
  if (sharedText.isEmpty) return;

  // Show a non-blocking floating progress overlay or loader
  showLoadingOverlay(context, "Resolving location shared...");

  final coords = await LocationSharingService.parseCoordinates(sharedText);
  if (coords == null) {
    hideLoadingOverlay();
    SnackbarService.showError("Failed to extract location details from shared link");
    return;
  }

  // Reverse geocode coords[1]=lat, coords[0]=lng
  final address = await LocationSharingService.reverseGeocode(coords[1], coords[0]);
  
  hideLoadingOverlay();

  // Navigate to AddTaskScreen with the prefilled values
  Navigator.push(
    context,
    MaterialPageRoute(
      builder: (context) => AddTaskScreen(
        initialCoordinates: coords,
        initialAddress: address ?? "Shared coordinates: ${coords[1]}, ${coords[0]}",
      ),
    ),
  );
}
```

